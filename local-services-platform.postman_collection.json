        {
          "name": "Create User from Keycloak SPI",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Keycloak-API-Key",
                "value": "{{keycloak_api_key}}",
                "description": "Required Keycloak API key (endpoint is public but protected by this key)"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"keycloakUserId\": \"{{user_id}}\",\n  \"email\": \"john.doe@example.com\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{gateway_url}}/user-service/keycloak/auth/create",
              "host": [
                "{{gateway_url}}"
              ],
              "path": [
                "user-service",
                "keycloak",
                "auth",
                "create"
              ]
            },
            "description": "Creates a new user based on data provided by the Keycloak SPI.\n\nPublic endpoint (no JWT token required), but protected by the X-Keycloak-API-Key header.\n\nReturns HTTP 201 with the created user data.\n\nFields:\n- keycloakUserId (String / UUID) – Keycloak user identifier\n- email (String) – email address\n- firstName (String) – first name\n- lastName (String) – last name"
          },
          "response": [
            {
              "name": "201 Created – user created",
              "originalRequest": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
